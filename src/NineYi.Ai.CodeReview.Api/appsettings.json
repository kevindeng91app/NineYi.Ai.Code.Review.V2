{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CodeReview.db"
  },
  "Dify": {
    "ApiEndpoint": "https://dify.91app.biz/v1/chat-messages",
    "CostPer1000Tokens": 0.002
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "PullRequestIgnore": {
    "TitleKeywords": ["[WIP]", "[SKIP]", "[NO-REVIEW]", "auto-", "chore:"]
  },
  "FileExclude": {
    "ExcludedPathPrefixes": [
      "/AutoGenerated/",
      "/i18n/",
      "/migrations/"
    ],
    "ExcludedFileExtensions": [
      ".designer.cs",
      ".typegen.ts",
      ".g.cs",
      ".min.js",
      ".min.css"
    ]
  },
  "_N1SECRETS": {
    "GitHub": {
      "WebhookSecret": "",
      "AccessToken": ""
    },
    "GitLab": {
      "WebhookSecret": "",
      "AccessToken": "",
      "ApiBaseUrl": ""
    },
    "Bitbucket": {
      "AccessToken": "",
      "Username": ""
    }
  }
}
