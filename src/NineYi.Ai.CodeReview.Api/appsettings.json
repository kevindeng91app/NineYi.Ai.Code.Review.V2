{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CodeReview.db"
  },
  "Dify": {
    "ApiEndpoint": "https://api.dify.ai/v1/workflows/run",
    "CostPer1000Tokens": 0.002
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "PullRequestIgnore": {
    "TitleKeywords": ["[WIP]", "[SKIP]", "[NO-REVIEW]", "auto-", "chore:"]
  },
  "_N1SECRETS": {
    "GitHub": {
      "WebhookSecret": ""
    },
    "GitLab": {
      "WebhookSecret": ""
    }
  }
}
